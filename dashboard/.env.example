# Tazent Dashboard Environment Variables
# Duplicate this file as '.env.local' to securely supply your secrets in production.

# Real Slack Integration Webhook
# Create an incoming webhook URL at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=your_slack_incoming_webhook_url_here

# Real GitHub Issue Tracking Integration
# Generate a Personal Access Token (classic or fine-grained with 'repo' write scope) at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here

# The repository where Tazent will create issue tickets (format: owner/repository)
# Example: diiviikk5/Tazent
GITHUB_REPO=owner/repository-name
